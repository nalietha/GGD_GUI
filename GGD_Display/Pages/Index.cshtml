@page
@model IndexModel
@{
    ViewData["Title"] = "GGD Home";
}

<!-- Header Menu -->
<nav class="navbar navbar-expand-lg navbar-light bg-light">
    <div class="container-fluid">
        <a class="navbar-brand" href="#">GGD</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link active" aria-current="page" href="#">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">Settings</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">Profile</a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<!-- Canvas Section -->
<div class="container mt-4">
    <div class="row">
        <!-- First Row of 8 Sections -->
        @for (int i = 0; i < 8; i++)
        {
            <div class="col-3 border p-3">
                <div class="canvas-item text-center">
                    <h5>Canvas @i</h5>
                    <input type="color" class="form-control my-2" />
                    <select class="form-select my-1">
                        <option>Option 1</option>
                        <option>Option 2</option>
                        <option>Option 3</option>
                    </select>
                    <select class="form-select my-1">
                        <option>Option 1</option>
                        <option>Option 2</option>
                        <option>Option 3</option>
                    </select>
                    <select class="form-select my-1">
                        <option>Option 1</option>
                        <option>Option 2</option>
                        <option>Option 3</option>
                    </select>
                </div>
            </div>
        }
    </div>
    <div class="row mt-3">
        <!-- Second Row of 8 Sections -->
        @for (int i = 8; i < 16; i++)
        {
            <div class="col-3 border p-3">
                <div class="canvas-item text-center">
                    <h5>Canvas @i</h5>
                    <input type="color" class="form-control my-2" />
                    <select class="form-select my-1">
                        <option>Option 1</option>
                        <option>Option 2</option>
                        <option>Option 3</option>
                    </select>
                    <select class="form-select my-1">
                        <option>Option 1</option>
                        <option>Option 2</option>
                        <option>Option 3</option>
                    </select>
                    <select class="form-select my-1">
                        <option>Option 1</option>
                        <option>Option 2</option>
                        <option>Option 3</option>
                    </select>
                </div>
            </div>
        }
    </div>
</div>
